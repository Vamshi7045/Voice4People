<%@ page import="java.util.List"%>
<%@ page import="com.voice4people.model.User"%>

<%
List<User> users =
(List<User>)request.getAttribute("users");
%>

<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<title>Users</title>

<style>

body{
    font-family:Arial;
    background:#f2f2f2;
}

.container{
    width:95%;
    margin:30px auto;
}

table{
    width:100%;
    border-collapse:collapse;
    background:white;
}

th{
    background:#0d6efd;
    color:white;
    padding:12px;
}

td{
    padding:10px;
    border:1px solid #ddd;
    text-align:center;
}

tr:nth-child(even){
    background:#f8f8f8;
}

</style>

</head>

<body>

<div class="container">

<h2>Registered Users</h2>

<table>

<tr>

<th>ID</th>
<th>Full Name</th>
<th>Email</th>
<th>Phone</th>
<th>Role</th>

</tr>

<%

if(users != null){

for(User u : users){

%>

<tr>

<td><%=u.getId()%></td>

<td><%=u.getFullName()%></td>

<td><%=u.getEmail()%></td>

<td><%=u.getPhone()%></td>

<td><%=u.getRole()%></td>

</tr>

<%

}

}

%>

</table>

</div>

</body>

</html>