<%@ page language="java"
    contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>

<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<title>Complaint Reports</title>

<style>

body{
    margin:0;
    font-family:Arial;
    background:#f4f6f9;
}

.container{
    width:90%;
    margin:40px auto;
}

h2{
    text-align:center;
    color:#0d6efd;
}

.cards{
    display:flex;
    gap:20px;
    flex-wrap:wrap;
    justify-content:center;
}

.card{
    width:220px;
    background:white;
    padding:25px;
    border-radius:10px;
    box-shadow:0 0 10px lightgray;
    text-align:center;
}

.card h3{
    color:#555;
}

.card h1{
    font-size:40px;
    color:#0d6efd;
}

.back{
    display:block;
    width:200px;
    margin:30px auto;
    padding:12px;
    text-align:center;
    background:#343a40;
    color:white;
    text-decoration:none;
    border-radius:5px;
}

.back:hover{
    background:#495057;
}

</style>

</head>

<body>

<div class="container">

<h2>📊 Complaint Reports</h2>

<div class="cards">

<div class="card">

<h3>Total Complaints</h3>

<h1><%=request.getAttribute("total")%></h1>

</div>

<div class="card">

<h3>Pending</h3>

<h1><%=request.getAttribute("pending")%></h1>

</div>

<div class="card">

<h3>In Progress</h3>

<h1><%=request.getAttribute("progress")%></h1>

</div>

<div class="card">

<h3>Resolved</h3>

<h1><%=request.getAttribute("resolved")%></h1>

</div>

</div>

<a href="adminDashboard.jsp" class="back">

⬅ Back to Dashboard

</a>

</div>

</body>

</html>	